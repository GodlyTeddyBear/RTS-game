option ServerOutput = "Generated/PlacementRemoteServer.luau"
option ClientOutput = "Generated/PlacementRemoteClient.luau"

option RemoteScope = "PLACEMENT_REMOTE"

struct PlaceRequest {
	GridId: string,
	CoordRow: u8,
	CoordCol: u8,
	StructureType: string,
}

struct PlaceResponse {
	Success: boolean,
	ErrorMessage: string?,
	InstanceId: u32?,
}

function PlaceStructure {
	Yield: Coroutine,
	Data: PlaceRequest,
	Return: PlaceResponse,
}
